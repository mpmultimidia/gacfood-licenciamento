{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2020"
    ],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "serve.ts",
    "api/**/*.ts",
    "config/**/*.ts",
    "licenciamento/**/*.ts",
    "repositorios/**/*.ts",
    "seguranca/**/*.ts",
    "servicos/**/*.ts",
    "supabase/**/*.ts",
    "tipos/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "frontend",
    "src",
    "dist"
  ]
}